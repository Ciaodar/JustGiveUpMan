<?xml version="1.0" encoding="utf-8"?>
<base xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" type="string">  <tags>
    <tag language="Türkçe" />
  </tags>
  <strings>
    <!-- Config -->
    <string id="jgum_test_msg" text="Just Give Up Man Doğru Bir Şekilde Yüklendi.!" />
    <string id="jgum_siege_surrender_offer_count" text="3" />
    <string id="jgum_siege_surrender_accept_count" text="2" />
    <string id="jgum_siege_surrender_reject_count" text="2" />
    <string id="jgum_field_surrender_offer_count" text="1" />
    <string id="jgum_field_surrender_accept_count" text="1" />
    <string id="jgum_field_surrender_reject_count" text="1" />

    <!-- Siege Surrender Dialogs -->
    <string id="jgum_siege_defender_greeting" text="Geldiğiniz için teşekkür ederim, {?CONVERSATION_NPC.GENDER}Leydim{?}Lordum{\\?}." />
    <string id="jgum_siege_player_siege_surrender_offer" text="Durumunuzun ciddi olduğunu görüyorum. Teslim olmak ve halkınızı daha fazla acı çekmekten kurtarmak ister misiniz?" />
    <string id="jgum_siege_surrender_offer_1" text="Haklısınız, {?CONVERSATION_NPC.GENDER}Leydim{?}Lordum{\\?}! Açlıktan kırılıyoruz. Kale sizindir; ne olur bizi bağışlayın." />
    <string id="jgum_siege_surrender_offer_2" text="Daha fazla dayanamayacağız. Lütfen merhamet et, kale senindir. Yeter ki bizi salıver" />
    <string id="jgum_siege_surrender_offer_3" text="Askerler isyanın eşiğinde, yiyecek kalmadı. Teslim oluyoruz. Bırak bizi gidelim kale de senin olsun!" />

    <!-- Accept -->
    <string id="jgum_siege_defender_accepted" text="Merhametinize minnettarız, {?CONVERSATION_NPC.GENDER}Leydim{?}Lordum{\\?}." />
    <string id="jgum_siege_surrender_accept_1" text="Sizi açlıktan kurtaran yeni efendiniz olarak merhamet ediyorum." />
    <string id="jgum_siege_surrender_accept_2" text="Akıllılık ettiniz. Silahlarınızı bırakın, canınızı bağışlıyorum." />

    <!-- Reject -->
    <string id="jgum_siege_defender_rejected" text="Kalradya bu zulmü unutmayacaktır!" />
    <string id="jgum_siege_surrender_reject_1" text="Bakalım aç karnına savaşabiliyor musunuz?" />
    <string id="jgum_siege_surrender_reject_2" text="Merhamet dilenmek için çok geç. Sizi ezmeye geliyorum." />

    <!-- Field Surrender Dialogs -->
    <string id="jgum_field_surrender_offer_1" text="Durun! Sizinle savaşamayız. Teslim oluyoruz!" />
    <string id="jgum_field_surrender_accept_1" text="Tesliminizi kabul ediyoruz. Silahlarınızı bırakın!" />
    <string id="jgum_field_surrender_reject_1" text="Hayır, hepiniz öleceksiniz. Hazırlanın!" />
    <string id="jgum_field_surrender_end" text="Akıllı bir karar. Canın bağışlandı." />
    <string id="jgum_field_surrender_success" text="Düşman kuvvetleri teslim oldu!" />
    <string id="jgum_field_surrender_rejected" text="Savaş devam ediyor!" />

    <!-- UI Strings -->
    <string id="jgum_siege_surrender_notification" text="{SETTLEMENT_NAME} kalesi komutanı teslim olmayı görüşmek istiyor." />
    <string id="jgum_siege_inquiry_title" text="Teslimiyet Teklifi" />
    <string id="jgum_siege_inquiry_accept" text="Görüşmeyi Kabul Et" />
    <string id="jgum_siege_inquiry_reject" text="Reddet" />
    <string id="jgum_siege_assault_triggered" text="Açlık savunmayı kırdı, taraflar açık savaşa sürüklendi!" />
    <string id="jgum_siege_starvation_sally_out" text="Açlıktan kırılan savunmacılar çaresiz bir huruç harekatı başlattı!" />

    <!-- Settings -->
    <string id="JGUM.Settings.SiegeSettings.Name" text="Genel Ayarlar" />
    <string id="JGUM.Settings.SurrenderTendencyMultiplier.Name" text="Genel Teslim Eğilimi" />
    <string id="JGUM.Settings.SurrenderTendencyMultiplier.Hint" text="Teslim olma şansının genel çarpanı. Daha yüksek değerler teslimiyetleri daha olası kılar." />
    <string id="JGUM.Settings.BaseSurrenderThreshold.Name" text="Temel Teslim Eşiği" />
    <string id="JGUM.Settings.BaseSurrenderThreshold.Hint" text="Teslim hesabı için temel değer. Daha yüksek değerler teslimiyetleri daha az olası kılar. Varsayılan 2.5." />
    <string id="JGUM.Settings.PlayerMercyMultiplier.Name" text="Oyuncu Merhamet Çarpanı" />
    <string id="JGUM.Settings.PlayerMercyMultiplier.Hint" text="Oyuncunun Merhamet/Zalimlik özelliği etkisi için çarpan. Varsayılan 100. 0 devre dışı bırakır. 200 iki katına çıkarır." />
    <string id="JGUM.Settings.LordCalculatingMultiplier.Name" text="Hesapçı Özellik Çarpanı" />
    <string id="JGUM.Settings.LordCalculatingMultiplier.Hint" text="Savunan lordların 'Hesapçı' özelliği için çarpan. Varsayılan 100." />
    <string id="JGUM.Settings.LordValorMultiplier.Name" text="Cesaret Özelliği Çarpanı" />
    <string id="JGUM.Settings.LordValorMultiplier.Hint" text="Savunan lordların 'Cesaret' özelliği için çarpan. Varsayılan 100." />
    <string id="JGUM.Settings.LordMercyMultiplier.Name" text="Merhamet Özelliği Çarpanı" />
    <string id="JGUM.Settings.LordMercyMultiplier.Hint" text="Savunan lordların 'Merhamet' özelliği için çarpan. Varsayılan 100." />
    <string id="JGUM.Settings.LordHonorMultiplier.Name" text="Şeref Özelliği Çarpanı" />
    <string id="JGUM.Settings.LordHonorMultiplier.Hint" text="Savunan lordların 'Şeref' özelliği için çarpan. Varsayılan 100." />
    <string id="JGUM.Settings.NearbyEnemyLordStrengthPercentage.Name" text="Yakındaki Düşman Lord Gücünün Etkisi (%)" />
    <string id="JGUM.Settings.NearbyEnemyLordStrengthPercentage.Hint" text="Yakındaki düşman lord gücünün kale savunucularının gücüne ekleme yüzdesi. Daha yüksek değerler savunucuların gücünü arttırır. Varsayılan %50." />
    <string id="JGUM.Settings.NearbyEnemyLordDetectionRange.Name" text="Düşman Lord Algılama Aralığı" />
    <string id="JGUM.Settings.NearbyEnemyLordDetectionRange.Hint" text="Yakında toplanan düşman lordları algılamak için ne kadar uzakta olabilecekleri (harita uzaklığında). Varsayılan 50." />
  </strings>
</base>