    <string id="JGUM.Settings.LordCalculatingMultiplier.Name" text="Hesapçı Özellik Çarpanı" />
    <string id="JGUM.Settings.LordCalculatingMultiplier.Hint" text="Teslimiyet formülünde Hesapçı özelliğinin etkisini çarpar." />

    <string id="JGUM.Settings.LordValorMultiplier.Name" text="Cesaret Özellik Çarpanı" />
    <string id="JGUM.Settings.LordValorMultiplier.Hint" text="Teslimiyet formülünde Cesaret özelliğinin etkisini çarpar." />

    <string id="JGUM.Settings.LordMercyMultiplier.Name" text="Merhamet Özellik Çarpanı" />
    <string id="JGUM.Settings.LordMercyMultiplier.Hint" text="Teslimiyet formülünde Merhamet özelliğinin etkisini çarpar." />

    <string id="JGUM.Settings.LordHonorMultiplier.Name" text="Onur Özellik Çarpanı" />
    <string id="JGUM.Settings.LordHonorMultiplier.Hint" text="Teslimiyet formülünde Onur özelliğinin etkisini çarpar." />

    <string id="JGUM.Settings.EnablePatrolSurrender.Name" text="Devriye Teslimiyetini Etkinleştir" />
    <string id="JGUM.Settings.EnablePatrolSurrender.Hint" text="Devriye veya lord olmayan düşman karşılaşmalarında teslimiyet diyaloglarını açar." />

    <string id="JGUM.Settings.PatrolDialogPriority.Name" text="Devriye Diyalog Önceliği" />
    <string id="JGUM.Settings.PatrolDialogPriority.Hint" text="Devriye teslimiyet satırları için diyalog öncelik değeri." />
  </strings>
